package main

import (
	"context"
	"crypto/tls"
	"encoding/json"
	"flag"
	"fmt"
	"log"
	"net"
	"net/http"
	"net/http/httputil"
	"net/url"
	"os"
	"os/exec"
	"path/filepath"
	"strings"
	"syscall"
	"time"
)

type Config struct {
	LuckyAPI       string `json:"lucky_api"`
	LuckyAPITarget string `json:"lucky_api_target"`
	APIProto       string `json:"api_proto"` // strict|prefer-https|prefer-http|force-https|force-http
	ConfigFile     string `json:"-"`
	Rules          []Rule `json:"rules"`
	Proxy          string `json:"proxy"`
	Cert           string `json:"cert"`
	Key            string `json:"key"`
	SmartDNSIP     string `json:"smartdns_ip"`
	SmartDSConf   string `json:"smartdns_conf"`
	SmartDSReload string `json:"smartdns_reload"`
	Interval       string `json:"interval"`
	LogFile        string `json:"log_file"` // 日志文件路径，默认程序同目录 hproxy.log
}

type Rule struct {
	Host   string   `json:"host"`
	Target []string `json:"target"` // 支持多个目标，可带协议头
	Proto  string   `json:"proto"`  // strict|prefer-https|prefer-http|force-https|force-http
}

var (
	cfg            Config
	allowedDomains map[string]bool  // 域名 → 是否代理
	apiRules       map[string]Rule  // Lucky API 域名 → Rule 对象
	fileRules      map[string]Rule  // config.json rules 域名 → Rule 对象
	wildRules      map[string]Rule  // config.json 通配符规则
	cert           tls.Certificate
	configModTime  time.Time
	smartdnsConfModTime time.Time  // SmartDNS 配置文件最后修改时间
	// 全局复用的 Transport，避免每次请求创建新连接导致 too many open files
	globalTransport = &http.Transport{
		TLSClientConfig:     &tls.Config{InsecureSkipVerify: true},
		MaxIdleConns:        50,               // 减少总空闲连接数
		MaxIdleConnsPerHost: 5,                // 减少每个 host 的空闲连接数
		IdleConnTimeout:     30 * time.Second, // 减少空闲连接超时时间
		DisableKeepAlives:   false,
		ForceAttemptHTTP2:   false, // 禁用 HTTP/2，减少复杂性
		// 添加超时设置，避免连接卡住
		ResponseHeaderTimeout: 30 * time.Second,
		ExpectContinueTimeout: 1 * time.Second,
	}
	// 全局复用的 DNS resolver，避免每次请求创建新的 UDP 连接
	globalResolver = &net.Resolver{
		PreferGo: true,
		Dial: func(ctx context.Context, network, address string) (net.Conn, error) {
			d := net.Dialer{Timeout: 5 * time.Second}
			return d.DialContext(ctx, "udp", "223.5.5.5:53")
		},
	}
)

func main() {
	// 调大文件描述符限制
	var rlimit syscall.Rlimit
	if err := syscall.Getrlimit(syscall.RLIMIT_NOFILE, &rlimit); err == nil {
		log.Printf("[Main] 当前 FD 限制: Cur=%d, Max=%d", rlimit.Cur, rlimit.Max)
		// 尝试设置到 65536 (OpenWrt 可能不支持这么高，会失败)
		targetFD := uint64(65536)
		if rlimit.Max < targetFD {
			targetFD = rlimit.Max
		}
		rlimit.Cur = targetFD
		rlimit.Max = targetFD
		if err := syscall.Setrlimit(syscall.RLIMIT_NOFILE, &rlimit); err != nil {
			log.Printf("[Main] 警告: 设置 FD=%d 失败: %v, 尝试 4096", targetFD, err)
			// 退回到 4096
			rlimit.Cur = 4096
			rlimit.Max = 4096
			syscall.Setrlimit(syscall.RLIMIT_NOFILE, &rlimit)
		}
		// 验证最终设置
		syscall.Getrlimit(syscall.RLIMIT_NOFILE, &rlimit)
		log.Printf("[Main] 最终 FD 限制: Cur=%d, Max=%d", rlimit.Cur, rlimit.Max)
	}
	configFlag := flag.String("config", "", "JSON 配置文件路径")
	flag.Parse()

	if *configFlag != "" {
		cfg.ConfigFile = *configFlag
		if err := loadConfig(*configFlag); err != nil {
			log.Fatalf("[Config] 加载失败: %v", err)
		}
	} else {
		// 未通过命令行指定配置，尝试加载当前目录下的 config.json
		if _, err := os.Stat("config.json"); err == nil {
			cfg.ConfigFile = "config.json"
			if err := loadConfig(cfg.ConfigFile); err != nil {
				log.Fatalf("[Config] 自动加载 config.json 失败: %v", err)
			}
			log.Printf("[Config] 自动加载 %s", cfg.ConfigFile)
		} else {
			log.Printf("[Config] 未指定 -config，且未找到 config.json，部分功能可能不可用")
		}
	}

	// 加载证书
	if err := loadCert(); err != nil {
		log.Printf("[Cert] 警告: %v", err)
	}

	// 日志直接写文件（避免 nohup 缓冲）
	logPath := "/root/hproxy.log"
	if cfg.ConfigFile != "" {
		logPath = filepath.Dir(cfg.ConfigFile) + "/hproxy.log"
	}
	if cfg.LogFile != "" {
		logPath = cfg.LogFile
	}
	// 用追加模式，避免截断之前的日志（包括 Setrlimit 的日志）
	logFile, err := os.OpenFile(logPath, os.O_CREATE|os.O_WRONLY|os.O_APPEND, 0644)
	if err == nil {
		log.SetOutput(logFile)
	}
	log.Printf("[Main] 日志文件: %s", logPath)

	// 初始更新
	updateSmartDNS()

	// 定时更新
	interval, _ := time.ParseDuration(cfg.Interval)
	if interval < time.Second {
		interval = 30 * time.Second
	}
	go func() {
		ticker := time.NewTicker(interval)
		defer ticker.Stop()
		for range ticker.C {
			updateSmartDNS()
		}
	}()

	// 启动 HTTP/HTTPS 服务（管理路由 + 代理）
	handler := http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
		switch r.URL.Path {
		case "/config":
			configHandler(w, r)
		case "/rules":
			rulesHandler(w, r)
		case "/logs":
			logsHandler(w, r)
		default:
			proxyHandler()(w, r)
		}
	})

	if cfg.SmartDNSIP != "" {
		// 使用自定义 ListenConfig 设置 socket 选项
		lc := net.ListenConfig{
			Control: func(network, address string, c syscall.RawConn) error {
				return c.Control(func(fd uintptr) {
					// 设置 SO_REUSEADDR 允许快速重启和重用 TIME_WAIT socket
					syscall.SetsockoptInt(int(fd), syscall.SOL_SOCKET, syscall.SO_REUSEADDR, 1)
				})
			},
		}
		ln, err := lc.Listen(context.Background(), "tcp", ":80")
		if err != nil {
			log.Fatalf("[Proxy] ❌ :80 端口被占用: %v", err)
		}
		log.Printf("[Proxy] HTTP 监听 :80")
		server80 := &http.Server{
			Addr:           ":80",
			Handler:        handler,
			MaxHeaderBytes: 1 << 20,
			IdleTimeout:    120 * time.Second,
			ReadTimeout:    30 * time.Second,
			WriteTimeout:   30 * time.Second,
		}
		go server80.Serve(ln)
	}
	if cfg.Cert != "" && cfg.Key != "" {
		lc := net.ListenConfig{
			Control: func(network, address string, c syscall.RawConn) error {
				return c.Control(func(fd uintptr) {
					// 设置 SO_REUSEADDR 允许快速重启和重用 TIME_WAIT socket
					syscall.SetsockoptInt(int(fd), syscall.SOL_SOCKET, syscall.SO_REUSEADDR, 1)
				})
			},
		}
		ln, err := lc.Listen(context.Background(), "tcp", ":443")
		if err != nil {
			log.Fatalf("[Proxy] ❌ :443 端口被占用: %v", err)
		}
		log.Printf("[Proxy] HTTPS 监听 :443")
		server443 := &http.Server{
			Addr:           ":443",
			Handler:        handler,
			MaxHeaderBytes: 1 << 20,
			IdleTimeout:    120 * time.Second,
			ReadTimeout:    30 * time.Second,
			WriteTimeout:   30 * time.Second,
		}
		go server443.ServeTLS(ln, cfg.Cert, cfg.Key)
	}

	log.Printf("=== 全部服务已启动 ===")
	select {}
}

func proxyHandler() http.HandlerFunc {
	return func(w http.ResponseWriter, r *http.Request) {
		host := strings.Split(r.Host, ":")[0]
		host = strings.TrimSpace(host)
	    target := matchRule(host, r.TLS != nil)

		if target == "" {
			// DIRECT 模式：查真实 IP
			log.Printf("[Proxy] DIRECT 模式: %s (TLS=%v)", host, r.TLS != nil)
		
			// 先检查是否是本地地址，避免不必要的 DNS 查询和循环代理
			// 去掉端口号，只保留主机名
			hostOnly := strings.Split(host, ":")[0]
			log.Printf("[Proxy] DIRECT 主机名: %s", hostOnly)
		
			// 检查本地地址
			isLocal := false
			if hostOnly == "127.0.0.1" || hostOnly == "::1" || hostOnly == "localhost" ||
			   strings.HasPrefix(hostOnly, "192.168.100.") ||
			   strings.HasPrefix(hostOnly, "10.0.") ||
			   strings.HasPrefix(hostOnly, "172.17.") {
				isLocal = true
			}
		
			if isLocal {
				// 设置 Connection: close，确保连接被关闭
				w.Header().Set("Connection", "close")
				http.Error(w, "503 Loop detected (local address)", http.StatusServiceUnavailable)
				log.Printf("[Proxy] ❌ 检测到本地地址: %s", host)
				return
			}
		
			addrs, err := globalResolver.LookupHost(context.Background(), host)
			if err != nil || len(addrs) == 0 {
				http.Error(w, "503 DNS lookup failed", http.StatusServiceUnavailable)
				log.Printf("[Proxy] ❌ DNS 查询失败: %s → %v", host, err)
				return
			}
		
			// 优先选择 IPv4 地址（避免 IPv6 问题）
			realIP := ""
			for _, addr := range addrs {
				if !strings.Contains(addr, ":") {
					// IPv4 地址
					realIP = addr
					break
				}
			}
			if realIP == "" {
				// 没有 IPv4，用第一个 IPv6 地址
				realIP = addrs[0]
			}
		
			port := "80"
			if r.TLS != nil {
				port = "443"
			}
			// IPv6 地址需要加方括号
			if strings.Contains(realIP, ":") {
				realIP = "[" + realIP + "]"
			}
			target = fmt.Sprintf("http://%s:%s", realIP, port)
			if r.TLS != nil {
				target = fmt.Sprintf("https://%s:%s", realIP, port)
			}
			log.Printf("[Proxy] ✅ DIRECT %s → %s", host, target)
		} else {
			// 规则匹配：根据客户端协议调整 target
			u, _ := url.Parse(target)
			target = u.String()
			log.Printf("[Proxy] ✅ 规则匹配 %s → %s (客户端%s)", host, target, map[bool]string{true: "HTTPS", false: "HTTP"}[r.TLS != nil])
		}

		proxy := &httputil.ReverseProxy{
			Director: func(req *http.Request) {
				u, _ := url.Parse(target)
				req.URL.Scheme = u.Scheme
				req.URL.Host = u.Host
				req.Host = r.Host
				req.Header.Set("Host", r.Host)
				req.Header.Set("X-Forwarded-For", r.RemoteAddr)
			},
			Transport: globalTransport,
		}
		proxy.ServeHTTP(w, r)
	}
}

func matchRule(host string, clientHTTPS bool) string {
	host = strings.Split(host, ":")[0]
	host = strings.TrimSpace(host)

	// 1. 检查是否在 config.json rules 里（完整域名）
	for _, rule := range cfg.Rules {
		if rule.Host == host && !strings.HasPrefix(rule.Host, "*.") {
			target := resolveTarget(rule, clientHTTPS)
			if target != "" {
				return target
			}
			break
		}
	}

	// 2. 检查是否在 Lucky API 域名列表里
	if rule, ok := apiRules[host]; ok {
		target := resolveTarget(rule, clientHTTPS)
		if target != "" {
			return target
		}
		return cfg.Proxy
	}

	// 3. 检查通配符规则（如 *.46.190564326.xyz），取最长匹配
	var bestTarget string
	bestLen := 0
	for d, rule := range wildRules {
		if strings.HasSuffix(host, d) {
			if len(d) > bestLen {
				bestLen = len(d)
				bestTarget = resolveTarget(rule, clientHTTPS)
			}
		}
	}
	if bestTarget != "" {
		return bestTarget
	}

	// 默认：返回空字符串（走 DIRECT 模式）
	return ""
}
func hasScheme(target string) bool {
	return strings.HasPrefix(target, "http://") || strings.HasPrefix(target, "https://")
}

func matchProto(target string, clientHTTPS bool) bool {
	if hasScheme(target) {
		return (clientHTTPS && strings.HasPrefix(target, "https://")) ||
			(!clientHTTPS && strings.HasPrefix(target, "http://"))
	}
	// target 无协议 → 默认不匹配
	return false
}

func resolveTarget(rule Rule, clientHTTPS bool) string {
	// 无 target → 请求真实 URL
	if len(rule.Target) == 0 {
		return ""
	}

	// 默认 strict 模式
	if rule.Proto == "" || rule.Proto == "strict" {
		for _, t := range rule.Target {
			if matchProto(t, clientHTTPS) {
				return t
			}
		}
		return "" // 没匹配到 → 请求真实 URL
	}

	// prefer-https: 优先 HTTPS，失败回退到客户端协议
	if rule.Proto == "prefer-https" {
		for _, t := range rule.Target {
			if hasScheme(t) && strings.HasPrefix(t, "https://") {
				return t
			}
		}
		return fallbackMatch(rule.Target, clientHTTPS)
	}

	// prefer-http: 优先 HTTP，失败回退到客户端协议
	if rule.Proto == "prefer-http" {
		for _, t := range rule.Target {
			if hasScheme(t) && strings.HasPrefix(t, "http://") {
				return t
			}
		}
		return fallbackMatch(rule.Target, clientHTTPS)
	}

	// force-https: 强制 HTTPS
	if rule.Proto == "force-https" {
		for _, t := range rule.Target {
			if hasScheme(t) && strings.HasPrefix(t, "https://") {
				return t
			}
		}
		for _, t := range rule.Target {
			if !hasScheme(t) {
				return "https://" + t
			}
		}
		return ""
	}

	// force-http: 强制 HTTP
	if rule.Proto == "force-http" {
		for _, t := range rule.Target {
			if hasScheme(t) && strings.HasPrefix(t, "http://") {
				return t
			}
		}
		for _, t := range rule.Target {
			if !hasScheme(t) {
				return "http://" + t
			}
		}
		return ""
	}

	// 默认：匹配客户端协议
	return fallbackMatch(rule.Target, clientHTTPS)
}

func fallbackMatch(targets []string, clientHTTPS bool) string {
	// 先尝试匹配客户端协议
	for _, t := range targets {
		if matchProto(t, clientHTTPS) {
			return t
		}
	}
	// 返回第一个可用的
	if len(targets) > 0 {
		return targets[0]
	}
	return ""
}

func loadConfig(path string) error {
	data, err := os.ReadFile(path)
	if err != nil {
		return err
	}
	if err := json.Unmarshal(data, &cfg); err != nil {
		return err
	}

	// 处理相对路径：证书路径相对于 config.json 所在目录
	if cfg.ConfigFile != "" {
		configDir := filepath.Dir(cfg.ConfigFile)
		if !filepath.IsAbs(cfg.Cert) && cfg.Cert != "" {
			cfg.Cert = filepath.Join(configDir, cfg.Cert)
		}
		if !filepath.IsAbs(cfg.Key) && cfg.Key != "" {
			cfg.Key = filepath.Join(configDir, cfg.Key)
		}
	}

	return nil
}

func updateSmartDNS() {
	changed := false

	// 1. 从 Lucky API 加载（过滤 46.）
	if loadFromAPI() {
		changed = true
	}

	// 2. 从 config.json rules 加载（不过滤）
	if loadRulesFromConf() {
		changed = true
	}

	// 3. 检查 SmartDNS 配置文件是否被修改
	if checkSmartDNSConfChanged() {
		changed = true
	}

	if changed {
		mergeAndReload()
	}
}

func loadFromAPI() bool {
	rules, err := fetchDomains()
	if err != nil {
		log.Printf("[SmartDNS] 获取 Lucky 域名失败: %v", err)
		return false
	}

	// 比较规则是否变化
	newRules := make(map[string]Rule)
	for _, rule := range rules {
		newRules[rule.Host] = rule
	}

	// 快速比较：数量不同则有变化
	if len(newRules) != len(apiRules) {
		apiRules = newRules
		log.Printf("[SmartDNS] API 域名更新: %d 个", len(apiRules))
		return true
	}

	// 逐一比较规则内容
	for host, newRule := range newRules {
		oldRule, ok := apiRules[host]
		if !ok || !ruleEqual(oldRule, newRule) {
			apiRules = newRules
			log.Printf("[SmartDNS] API 域名更新: %d 个", len(apiRules))
			return true
		}
	}

	return false
}

func loadRulesFromConf() bool {
	// 快速检查：文件未改动就返回
	if cfg.ConfigFile != "" {
		info, err := os.Stat(cfg.ConfigFile)
		if err == nil && !info.ModTime().After(configModTime) {
			return false
		}
		configModTime = time.Now()
	}

	fileNew := make(map[string]Rule)
	for _, rule := range cfg.Rules {
		if rule.Host != "" {
			fileNew[rule.Host] = rule
		}
	}

	// 快速比较：数量不同则有变化
	if len(fileNew) != len(fileRules) {
		fileRules = fileNew
		log.Printf("[SmartDNS] Rules 域名更新: %d 个", len(fileRules))
		return true
	}

	// 逐一比较规则内容
	for host, newRule := range fileNew {
		oldRule, ok := fileRules[host]
		if !ok || !ruleEqual(oldRule, newRule) {
			fileRules = fileNew
			log.Printf("[SmartDNS] Rules 域名更新: %d 个", len(fileRules))
			return true
		}
	}

	return false
}

func checkSmartDNSConfChanged() bool {
	// 检查 SmartDNS 主配置文件 (smartdns.conf) 是否被修改
	smartdnsConf := "/var/etc/smartdns/smartdns.conf"

	info, err := os.Stat(smartdnsConf)
	if err != nil {
		return false
	}

	if info.ModTime().After(smartdnsConfModTime) {
		smartdnsConfModTime = info.ModTime()
		log.Printf("[SmartDNS] 主配置文件已修改: %s", smartdnsConf)
		return true
	}

	return false
}

func mergeAndReload() {
	wildRules = make(map[string]Rule)
	domains := make(map[string]bool)

	for d, rule := range apiRules {
		if strings.HasPrefix(d, "*") {
			idx := strings.IndexByte(d, '.')
			if idx == -1 || idx == len(d)-1 {
				// 没有 '.' 或 '.' 后没有内容，跳过
				continue
			}
            wildRules[strings.TrimPrefix(d,"*")] = rule

			d = d[idx+1:]
		}
		domains[d] = true
	}
	for d, rule := range fileRules {
			if strings.HasPrefix(d, "*") {
			idx := strings.IndexByte(d, '.')
			if idx == -1 || idx == len(d)-1 {
				// 没有 '.' 或 '.' 后没有内容，跳过
				continue
			}
			wildRules[strings.TrimPrefix(d,"*")] = rule


			d = d[idx+1:]

		}
		domains[d] = true
	}

	// 生成 SmartDNS 配置
	lines := []string{
		fmt.Sprintf("# Auto-generated by hostproxy @ %s", time.Now().Format("2006-01-02 15:04:05")),
		fmt.Sprintf("# Total: %d domains", len(domains)),
		fmt.Sprintf("# Target IP: %s", cfg.SmartDNSIP),
		"",
	}
	for d := range domains {
		lines = append(lines, fmt.Sprintf("address /%s/%s", d, cfg.SmartDNSIP))
	}
	content := strings.Join(lines, "\n")

	// 写到 /tmp/lucky-domains.conf
	if err := os.WriteFile(cfg.SmartDSConf, []byte(content), 0644); err != nil {
		log.Printf("[SmartDNS] 写文件失败: %v", err)
		return
	}
	// 更新文件修改时间记录
	if info, err := os.Stat(cfg.SmartDSConf); err == nil {
		smartdnsConfModTime = info.ModTime()
	}

	// 确保 smartdns.conf 包含 conf-file 指令
	ensureConfFile()

	// reload SmartDNS
	reloadSmartDNS()

	allowedDomains=domains
}

func ensureConfFile() {
	smartdnsConf := "/var/etc/smartdns/smartdns.conf" // 默认路径
	if cfg.SmartDSConf != "" {
		// 从 SmartDSConf 推导 smartdns.conf 路径（去掉文件名）
		// 或者直接读配置里的路径
	}

	data, err := os.ReadFile(smartdnsConf)
	if err != nil {
		log.Printf("[SmartDNS] 读 smartdns.conf 失败: %v", err)
		return
	}

	confFileLine := "conf-file " + cfg.SmartDSConf
	if strings.Contains(string(data), confFileLine) {
		return // 已有，不用加
	}

	// 追加到末尾
	f, err := os.OpenFile(smartdnsConf, os.O_APPEND|os.O_WRONLY, 0644)
	if err != nil {
		log.Printf("[SmartDNS] 打开 smartdns.conf 失败: %v", err)
		return
	}
	defer f.Close()

	if _, err := f.WriteString("\n" + confFileLine + "\n"); err != nil {
		log.Printf("[SmartDNS] 追加 conf-file 失败: %v", err)
		return
	}
	log.Printf("[SmartDNS] 已添加 conf-file 到 smartdns.conf")
}

func reloadSmartDNS() {
	cmd := exec.Command("sh", "-c", cfg.SmartDSReload)
	if err := cmd.Run(); err != nil {
		log.Printf("[SmartDNS] reload 失败: %v", err)
	} else {
		log.Printf("[SmartDNS] ✅ 配置已更新并 reload")
	}
}

func fetchDomains() ([]Rule, error) {
	var result []Rule

	if cfg.LuckyAPI == "" {
		return result, fmt.Errorf("LuckyAPI not configured")
	}

	// 调用 Lucky API
	req, err := http.NewRequest("GET", cfg.LuckyAPI, nil)
	if err != nil {
		return result, err
	}
	req.Header.Set("User-Agent", "Mozilla/5.0")
	req.Header.Set("Accept", "application/json")

	client := &http.Client{
		Timeout:   10 * time.Second,
		Transport: globalTransport,
	}
	resp, err := client.Do(req)
	if err != nil {
		return result, err
	}
	defer resp.Body.Close()

	if resp.StatusCode != 200 {
		return result, fmt.Errorf("API 返回状态码 %d", resp.StatusCode)
	}

	// 解析响应
	var data struct {
		Ret      int `json:"ret"`
		RuleList []struct {
			RuleName   string `json:"RuleName"`
			ListenPort int    `json:"ListenPort"`
			ProxyList  []struct {
				Domains []string `json:"Domains"`
			} `json:"ProxyList"`
		} `json:"ruleList"`
	}
	if err := json.NewDecoder(resp.Body).Decode(&data); err != nil {
		return result, err
	}

	// 过滤：RuleName=Lucky_https + ListenPort=2053 + Domains 含 "46." → 组装成 Rule 对象
	for _, rule := range data.RuleList {
		if rule.RuleName != "Lucky_https" || rule.ListenPort != 2053 {
			continue
		}
		for _, proxy := range rule.ProxyList {
			for _, domain := range proxy.Domains {
				// 去掉路径部分（如 ssl46.190564326.xyz/myweb → ssl46.190564326.xyz）
				domain = strings.Split(domain, "/")[0]
				if strings.Contains(domain, "46.") {
					result = append(result, Rule{
						Host:   domain,
						Target: []string{cfg.LuckyAPITarget},
						Proto:  cfg.APIProto, // 统一使用 api_proto 配置
					})
				}
			}
		}
	}

	log.Printf("[Lucky API] 获取到 %d 个域名", len(result))
	return result, nil
}

func mapsEqual(a, b map[string]bool) bool {
	if len(a) != len(b) {
		return false
	}
	for k := range a {
		if !b[k] {
			return false
		}
	}
	return true
}

// ruleEqual compares two Rule objects (safely compares slices)
func ruleEqual(a, b Rule) bool {
	if a.Host != b.Host || a.Proto != b.Proto {
		return false
	}
	if len(a.Target) != len(b.Target) {
		return false
	}
	for i := range a.Target {
		if a.Target[i] != b.Target[i] {
			return false
		}
	}
	return true
}

func loadCert() error {
	if cfg.Cert == "" || cfg.Key == "" {
		return nil // no cert configured
	}
	var err error
	cert, err = tls.LoadX509KeyPair(cfg.Cert, cfg.Key)
	return err
}

// --- 管理接口 ---

func configHandler(w http.ResponseWriter, r *http.Request) {
	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(cfg)
}

func rulesHandler(w http.ResponseWriter, r *http.Request) {
	type RuleInfo struct {
		Source string `json:"source"`
		Host   string `json:"host"`
		Rule   Rule   `json:"rule"`
	}
	var list []RuleInfo
	for h, rule := range apiRules {
		list = append(list, RuleInfo{Source: "api", Host: h, Rule: rule})
	}
	for h, rule := range fileRules {
		list = append(list, RuleInfo{Source: "file", Host: h, Rule: rule})
	}
	for d, rule := range wildRules {
		list = append(list, RuleInfo{Source: "wild", Host: d, Rule: rule})
	}
	w.Header().Set("Content-Type", "application/json")
	json.NewEncoder(w).Encode(list)
}

func logsHandler(w http.ResponseWriter, r *http.Request) {
	path := "/root/hproxy.log"
	if cfg.ConfigFile != "" {
		path = filepath.Dir(cfg.ConfigFile) + "/hproxy.log"
	}
	if cfg.LogFile != "" {
		path = cfg.LogFile
	}
	debug := fmt.Sprintf("cfg.ConfigFile=%s, cfg.LogFile=%s, path=%s", cfg.ConfigFile, cfg.LogFile, path)
	log.Printf("[Logs] %s", debug)
	data, err := os.ReadFile(path)
	if err != nil {
		http.Error(w, debug+"\n"+err.Error(), 500)
		return
	}
	w.Header().Set("Content-Type", "text/plain; charset=utf-8")
	w.Write(data)
}
